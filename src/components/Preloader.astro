---
/* src/components/Preloader.astro */
---
<div id="preloader" class="fixed inset-0 z-100 flex flex-col items-center justify-center bg-zinc-950 px-6 overflow-hidden">
  
  <div id="pixie-dust" class="absolute inset-0 pointer-events-none"></div>

  <div class="relative flex flex-col items-center w-full max-w-5xl">
    
    <div class="overflow-hidden mb-12 text-center z-10">
      <p id="preloader-text" class="text-4xl md:text-6xl lg:text-7xl text-pink-100 font-parisienne opacity-0 tracking-widest translate-y-full drop-shadow-[0_0_20px_rgba(255,255,255,0.4)]">
        Los 15 de Sofía
      </p>
      <span id="loading-sub" class="block text-[12px] md:text-xl lg:text-2xl tracking-[0.5em] md:tracking-[0.8em]  text-pink-200/50 mt-6 opacity-0 font-medium italic">
        La magia comienza ahora
      </span>
    </div>

    <div class="relative w-full max-w-70 md:max-w-md lg:max-w-lg aspect-square flex items-center justify-center">
      <svg class="absolute inset-0 w-full h-full -rotate-12 scale-150 pointer-events-none" viewBox="0 0 100 100">
        <path 
          id="magic-arc" 
          d="M 5,80 A 45,45 0 0 1 95,80" 
          fill="none" 
          stroke="url(#arc-gradient)" 
          stroke-width="0.5" 
          stroke-linecap="round"
          class="opacity-0"
        />
        <defs>
          <linearGradient id="arc-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="transparent" />
            <stop offset="50%" stop-color="#fef08a" />
            <stop offset="100%" stop-color="transparent" />
          </linearGradient>
        </defs>
      </svg>

      <img 
        id="castle-png"
        src="/castillo.png" 
        alt="Castillo" 
        class="w-full h-full object-contain opacity-0 scale-90 filter drop-shadow-[0_0_30px_rgba(251,113,133,0.4)]" 
      />
      <div id="castle-glow" class="absolute inset-0 bg-white/10 rounded-full blur-[80px] opacity-0 scale-50"></div>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  const createPixieDust = () => {
    const container = document.getElementById('pixie-dust');
    if (!container) return;
    for (let i = 0; i < 40; i++) {
      const dot = document.createElement('div');
      dot.className = 'absolute w-1 h-1 bg-white rounded-full opacity-0';
      container.appendChild(dot);
      gsap.set(dot, {
        x: Math.random() * window.innerWidth,
        y: Math.random() * window.innerHeight,
        scale: Math.random() * 1.5
      });
      gsap.to(dot, {
        opacity: Math.random() * 0.6,
        y: "-=150",
        duration: 4 + Math.random() * 3,
        repeat: -1,
        ease: "none",
        delay: Math.random() * 5
      });
    }
  };

  const startLoader = () => {
    const preloader = document.getElementById('preloader');
    const castle = document.getElementById('castle-png');
    const title = document.getElementById('preloader-text');
    const subtitle = document.getElementById('loading-sub');
    const arc = document.getElementById('magic-arc');
    const glow = document.getElementById('castle-glow');
    const html = document.documentElement;

    if (!preloader) return;

    html.style.overflow = 'hidden';
    createPixieDust();

    const tl = gsap.timeline();

    // 1. Aparece el texto con elegancia
    tl.to(title, { opacity: 1, y: 0, duration: 1.5, ease: "power4.out" });
    
    // Animación de espaciado dinámico según pantalla
    tl.to(subtitle, { 
      opacity: 1, 
      duration: 1.2, 
      letterSpacing: window.innerWidth > 768 ? "1.2em" : "0.6em" 
    }, "-=1");
    
    // 2. Revelado del castillo
    tl.to(castle, { opacity: 1, scale: 1, duration: 2, ease: "expo.out" }, "-=0.5");
    tl.to(glow, { opacity: 0.8, scale: 2, duration: 2, ease: "power2.inOut" }, "-=2");

    // 3. Animación del Arco Mágico (Stroke draw)
    tl.set(arc, { opacity: 1, strokeDasharray: 300, strokeDashoffset: 300 }, "-=1.5");
    tl.to(arc, { 
      strokeDashoffset: 0, 
      duration: 2.5, 
      ease: "power1.inOut" 
    }, "-=1.5");

    // 4. Desvanecimiento final con escala suave
    tl.to(preloader, {
      opacity: 0,
      scale: 1.05,
      duration: 1.2,
      delay: 0.8,
      ease: "power2.inOut",
      onComplete: () => {
        preloader.style.display = 'none';
        html.style.overflow = '';
        window.dispatchEvent(new Event('preloaderFinished'));
      }
    });
  };

  window.addEventListener('load', startLoader);
  document.addEventListener('astro:page-load', startLoader);
</script>

<style>
  .font-parisienne {
    font-family: 'Parisienne', cursive;
  }
  #pixie-dust div {
    box-shadow: 0 0 8px #fff;
  }
  #loading-sub {
    text-shadow: 0 0 15px rgba(244, 114, 182, 0.3);
  }
</style>