---
import { Music, ChevronDown } from '@lucide/astro';
---


<section id="hero-section" class="relative min-h-screen w-full flex flex-col items-center justify-between py-8 md:py-12 overflow-hidden bg-zinc-950">
  
  <div class="absolute inset-0 z-0 flex items-center justify-center">
    <img 
      id="hero-img"
      src="/hero.jpeg" 
      alt="Fondo Hero" 
      class="h-full w-full object-cover md:object-contain opacity-0 scale-120" 
    />
    <div class="absolute inset-0 bg-linear-to-b from-zinc-950/60 via-transparent to-zinc-950/70"></div>
    <div class="absolute inset-0 bg-purple-900/5 mix-blend-overlay"></div>
  </div>

  <div class="z-10 px-6 text-center mt-12 md:mt-20">
    <p class="hero-element opacity-0 text-xl md:text-2xl text-pink-300/70 mb-2">
      Te invito a mis 15 años
    </p>
    <h1 class="hero-element opacity-0 text-7xl sm:text-8xl md:text-[11rem] gold-text leading-tight py-4">
      Sofia Parra
    </h1>
  </div>

  <div class="z-10 flex flex-col items-center gap-4 px-6 text-center">
    <div class="hero-element opacity-0">
        <button 
          id="play-button"
          class="group relative flex items-center justify-center w-14 h-14 md:w-16 md:h-16 bg-purple-200/10 backdrop-blur-lg border border-pink-200/20 rounded-full transition-all hover:scale-110 active:scale-95 shadow-2xl"
        >
          <div id="ping-effect" class="absolute inset-0 rounded-full bg-pink-400/20 animate-ping opacity-60"></div>
          <Music class="size-6 md:size-7 text-pink-100 relative z-20" />
        </button>
    </div>
    <p id="music-text" class="hero-element opacity-0 text-lg md:text-xl tracking-wide text-purple-200/50 font-light">
      Música para tu entrada
    </p>
    <audio id="bg-music" src="/music.mp3" loop></audio>
  </div>

  <div class="hero-element opacity-0 z-10 flex flex-col items-center gap-2 text-pink-200/30 animate-bounce mb-6 md:mb-10">
    <span class="text-sm tracking-widest ">Desliza</span>
    <ChevronDown class="size-4 md:size-5" />
  </div>

</section>

<style>
  .gold-text {
    background: linear-gradient(to bottom, #fff9c4 0%, #fde047 25%, #d4af37 50%, #ca8a04 75%, #854d0e 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.5));
    font-family: var(--font-parisienne);
  }

  .glow-active {
    border-color: rgba(244, 114, 182, 0.5);
    box-shadow: 0 0 30px rgba(244, 114, 182, 0.3);
    background: rgba(216, 180, 254, 0.2);
  }
</style>

<script>
  import { gsap } from "gsap";

  const startHeroSequence = () => {
    const tl = gsap.timeline();

    tl.to("#hero-img", {
        opacity: 0.55,
        scale: 1.05,
        duration: 2.5,
        ease: "power2.out"
    });

    tl.fromTo(".hero-element", 
      { y: 50, opacity: 0, filter: "blur(15px)" }, 
      { 
        y: 0, 
        opacity: 1, 
        filter: "blur(0px)", 
        duration: 1.5, 
        stagger: 0.4, 
        ease: "expo.out" 
      },
      "-=2"
    );
  };

  // Escuchar el final del preloader
  window.addEventListener('preloaderFinished', startHeroSequence);

  // Lógica de Audio
  const button = document.getElementById('play-button');
  const audio = document.getElementById('bg-music') as HTMLAudioElement;
  const text = document.getElementById('music-text');
  const ping = document.getElementById('ping-effect');

  button?.addEventListener('click', () => {
    if (audio.paused) {
      audio.play().catch(() => {});
      button.classList.add('glow-active');
      ping?.classList.add('hidden');
      if(text) text.innerText = "Disfruta la música";
    } else {
      audio.pause();
      button.classList.remove('glow-active');
      ping?.classList.remove('hidden');
      if(text) text.innerText = "Música en pausa";
    }
  });
</script>