---
import { Timer } from '@lucide/astro';

// Define la fecha aquí para que sea fácil de cambiar
const targetDate = "2026-10-15T20:00:00"; 
---

<section class="py-12 px-6 flex flex-col items-center justify-center bg-accent/5 rounded-3xl mx-4 my-20 border border-accent/10">
  <div class="flex items-center gap-2 mb-8 text-accent">
    <Timer size={20} />
    <span class="uppercase tracking-[0.2em] text-xs font-medium">Faltan pocos días</span>
  </div>

  <div id="countdown" data-date={targetDate} class="flex gap-4 md:gap-8 justify-center items-center">
    <div class="flex flex-col items-center">
      <span id="days" class="text-4xl md:text-6xl font-display italic text-zinc-800">00</span>
      <span class="text-[10px] uppercase tracking-widest text-zinc-400 mt-2">Días</span>
    </div>
    <span class="text-2xl text-accent/30 self-start mt-2">:</span>
    
    <div class="flex flex-col items-center">
      <span id="hours" class="text-4xl md:text-6xl font-display italic text-zinc-800">00</span>
      <span class="text-[10px] uppercase tracking-widest text-zinc-400 mt-2">Horas</span>
    </div>
    <span class="text-2xl text-accent/30 self-start mt-2">:</span>

    <div class="flex flex-col items-center">
      <span id="minutes" class="text-4xl md:text-6xl font-display italic text-zinc-800">00</span>
      <span class="text-[10px] uppercase tracking-widest text-zinc-400 mt-2">Min</span>
    </div>
    <span class="text-2xl text-accent/30 self-start mt-2">:</span>

    <div class="flex flex-col items-center">
      <span id="seconds" class="text-4xl md:text-6xl font-display italic text-accent">00</span>
      <span class="text-[10px] uppercase tracking-widest text-zinc-400 mt-2">Seg</span>
    </div>
  </div>
</section>

<script>
  function updateCountdown() {
    const countdownElement = document.getElementById('countdown');
    const target = new Date(countdownElement?.dataset.date || "").getTime();
    
    const now = new Date().getTime();
    const diff = target - now;

    if (diff <= 0) {
      if (countdownElement) countdownElement.innerHTML = "<p class='text-2xl font-display italic text-accent'>¡Hoy es el gran día!</p>";
      return;
    }

    // Cálculos de tiempo
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((diff % (1000 * 60)) / 1000);

    // Actualizar el DOM con formato de dos dígitos
    const d = document.getElementById('days');
    const h = document.getElementById('hours');
    const m = document.getElementById('minutes');
    const s = document.getElementById('seconds');

    if (d) d.innerText = days.toString().padStart(2, '0');
    if (h) h.innerText = hours.toString().padStart(2, '0');
    if (m) m.innerText = minutes.toString().padStart(2, '0');
    if (s) s.innerText = seconds.toString().padStart(2, '0');
  }

  // Ejecutar cada segundo
  setInterval(updateCountdown, 1000);
  // Ejecutar inmediatamente al cargar
  updateCountdown();
</script>