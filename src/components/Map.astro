---
import { MapPin, Sparkles } from '@lucide/astro';

interface Props {
  address: string;
}

const { address } = Astro.props;

// La URL exacta que extraje de tu iframe
const mapUrl = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3920.8577919466306!2d-71.6194269!3d10.6681444!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e8998e02ece13a5%3A0x1ae5d0197b97dc98!2sHotel%20Jolie!5e0!3m2!1ses-419!2sve!4v1774965904089!5m2!1ses-419!2sve";
---

<section class="py-16 md:py-24 px-4 relative overflow-hidden w-full">
  <div class="absolute inset-0 pointer-events-none z-0 opacity-60">
    {[...Array(12)].map((_, i) => (
      <div 
        class="absolute w-1 h-1 bg-yellow-400 rounded-full shadow-[0_0_8px_2px_rgba(251,191,36,0.3)] animate-glitter"
        style={`
          top: ${Math.random() * 100}%;
          left: ${Math.random() * 100}%;
          animation-delay: ${Math.random() * 5}s;
          animation-duration: ${4 + Math.random() * 4}s;
        `}
      />
    ))}
  </div>

  <div class="max-w-4xl mx-auto text-center space-y-12 relative z-10">
    
    <div class="flex flex-col items-center gap-4">
      <div class="p-4 rounded-full bg-white/40 backdrop-blur-md border border-white/60 shadow-sm animate-float">
        <MapPin class="text-rose-400 size-8 drop-shadow-sm" />
      </div>
      
      <div class="space-y-3">
        <h2 class="font-anydore text-5xl md:text-7xl text-zinc-800 drop-shadow-sm">Ubicación</h2>
        
        <div class="flex items-center justify-center gap-4 text-rose-300/60">
            <Sparkles size={16} class="animate-pulse" />
            <div class="h-px w-20 bg-linear-to-r from-transparent via-rose-300/40 to-transparent"></div>
            <Sparkles size={16} class="animate-pulse" />
        </div>

        <p class="text-zinc-500 tracking-[0.25em] text-[10px] md:text-xs font-bold mt-6 px-4 leading-relaxed max-w-md mx-auto">
          {address}
        </p>
      </div>
    </div>

    <div class="relative group max-w-3xl mx-auto">
        <div class="absolute -inset-1 bg-linear-to-r from-rose-200 via-white to-purple-200 rounded-[2.5rem] md:rounded-[3.5rem] blur-2xl opacity-20 group-hover:opacity-40 transition duration-1000"></div>
        
        <div class="relative aspect-video rounded-4xl md:rounded-[3.5rem] overflow-hidden shadow-2xl shadow-rose-200/30 border-10 border-white bg-white/40 backdrop-blur-sm">
          <iframe 
            src={mapUrl} 
            width="100%" 
            height="100%" 
            style="border:0; filter: contrast(1.1) brightness(1.02) saturate(0.9);" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            class="transition-all duration-1000 group-hover:scale-105"
          >
          </iframe>
          
          <div class="absolute inset-0 pointer-events-none border-px border-white/30 rounded-4xl md:rounded-[3.5rem]"></div>
        </div>

        <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 z-20 w-full flex justify-center">
          <a 
            href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white px-10 py-4 rounded-full shadow-xl border border-rose-100 text-rose-400 font-bold text-[10px] md:text-xs tracking-[0.3em] hover:bg-rose-50 hover:scale-110 transition-all duration-500"
          >
            Cómo llegar
          </a>
        </div>
    </div>
  </div>
</section>

<style>
  @reference "tailwindcss";

  .font-anydore {
    font-family: 'Anydore', 'Parisienne', cursive;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes glitter {
    0%, 100% { opacity: 0; transform: scale(0.3) translateY(0); }
    25% { opacity: 0.8; transform: scale(1) translateY(-15px); }
    75% { opacity: 0.4; transform: scale(0.7) translateY(-30px); }
  }
  .animate-glitter {
    animation: glitter linear infinite;
  }
</style>