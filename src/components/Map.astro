---
import { MapPin } from '@lucide/astro';
const { address, mapUrl } = Astro.props;
---
<section class="py-20 px-6 max-w-4xl mx-auto text-center space-y-8">
  <div class="flex flex-col items-center gap-2">
    <MapPin class="text-accent size-8" />
    <h2 class="font-display text-4xl italic">Ubicación</h2>
    <p class="text-zinc-500">{address}</p>
  </div>
  
  <div class="aspect-video rounded-3xl overflow-hidden shadow-2xl shadow-accent/5 border border-zinc-200">
    <iframe 
      src={mapUrl} 
      width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy">
    </iframe>
  </div>
</section>