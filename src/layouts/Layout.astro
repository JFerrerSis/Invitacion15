---
import "../styles/global.css";
import Preloader from "../components/Preloader.astro";
import SparkleEffect from "../components/SparkleEffect.astro";
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="theme-color" content="#f3e8ff" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <link rel="icon" type="image/svg+xml" href="/castillo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Parisienne&display=swap"
      rel="stylesheet"
    />
    <meta name="theme-color" content="#f3e8ff" />
    <title>{title}</title>
  </head>
  <body
    class="m-0 p-0 w-full min-h-screen bg-linear-to-br from-pastel-pink to-pastel-purple bg-fixed relative"
  >
    <div
      class="fixed inset-0 bg-linear-to-br from-pastel-pink to-pastel-purple -z-10 bg-fixed"
    >
    </div>

    <SparkleEffect />

    <main id="main-container" class="relative w-full">
      <Preloader />
      <slot />
    </main>

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { ScrollToPlugin } from "gsap/ScrollToPlugin";

      gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

      const initGSAPScroll = () => {
        // 1. QUITAMOS normalizeScroll(true) que es lo que bloquea el touch en muchos móviles
        // En su lugar, si quieres suavidad, usa una configuración ligera o simplemente deja el nativo.

        const reveals = document.querySelectorAll(".reveal");
        reveals.forEach((el) => {
          gsap.fromTo(
            el,
            {
              opacity: 0,
              y: 40, // Bajamos un poco la intensidad del salto para que sea más fluido
              filter: "blur(10px)",
              scale: 0.98,
            },
            {
              opacity: 1,
              y: 0,
              filter: "blur(0px)",
              scale: 1,
              duration: 1,
              ease: "power2.out",
              scrollTrigger: {
                trigger: el,
                start: "top 90%",
                end: "bottom 10%",
                toggleActions: "play reverse play reverse",
              },
            },
          );
        });

        const anchors =
          document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]');
        anchors.forEach((anchor) => {
          anchor.addEventListener("click", (e) => {
            e.preventDefault();
            const target = anchor.getAttribute("href");
            if (target) {
              gsap.to(window, {
                duration: 1.2,
                scrollTo: { y: target, autoKill: true },
                ease: "power3.inOut",
              });
            }
          });
        });
      };

      document.addEventListener("astro:page-load", initGSAPScroll);
      if (document.readyState === "complete") {
        initGSAPScroll();
      } else {
        window.addEventListener("load", initGSAPScroll);
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Forzamos el color de fondo a nivel raíz */
    background-color: #f3e8ff; 
  }

  html {
    /* Evita el salto blanco del notch y la barra de gestos */
    height: -webkit-fill-available;
    overflow-x: hidden;
    scroll-behavior: smooth;
    /* Esto quita el rebote elástico que engrosa la barra */
    overscroll-behavior-y: none; 
  }

  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100vh;
    min-height: -webkit-fill-available;
    /* Importante para que el scroll táctil sea nativo y no se trabe */
    touch-action: pan-y; 
    -webkit-overflow-scrolling: touch;
    overflow-x: hidden;
    /* El fondo debe estar aquí también por si acaso */
    background: linear-gradient(180deg, #fce7f3 0%, #f3e8ff 100%) fixed;
  }

  main {
    width: 100%;
    position: relative;
    /* Padding dinámico para que la raya de gestos flote sobre el diseño y no lo empuje */
    padding-bottom: env(safe-area-inset-bottom);
  }

  /* Aseguramos que el div del fondo ocupe TODO incluyendo la zona de la raya */
  .fixed-background {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -10;
    /* Usamos bloque de color sólido abajo para que no haya blanco */
    background-color: #f3e8ff; 
  }

  .reveal {
    opacity: 0;
    will-change: transform, opacity, filter;
  }
</style>
