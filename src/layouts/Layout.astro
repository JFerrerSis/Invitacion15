---
import '../styles/global.css';
import Preloader from '../components/Preloader.astro';

interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
        <link rel="icon" type="image/svg+xml" href="/castillo.png" />
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Parisienne&display=swap" rel="stylesheet">
        
        <title>{title}</title>
    </head>
    <body class="m-0 p-0 w-full min-h-screen bg-linear-to-br from-pastel-pink to-pastel-purple bg-fixed overflow-x-hidden relative">
        
        <main class="relative w-full overflow-x-hidden">
            <Preloader /><slot />
        </main>

        <script>
            import { gsap } from "gsap";
            import { ScrollTrigger } from "gsap/ScrollTrigger";

            gsap.registerPlugin(ScrollTrigger);

            const animateReveals = () => {
                const elements = document.querySelectorAll('.reveal');
                
                elements.forEach((el) => {
                    gsap.fromTo(el, 
                        { 
                            opacity: 0, 
                            y: 40,
                            filter: "blur(10px)"
                        }, 
                        {
                            opacity: 1,
                            y: 0,
                            filter: "blur(0px)",
                            duration: 1.2,
                            ease: "power2.out",
                            clearProps: "all", // Limpia los estilos de GSAP al terminar para evitar bugs de scroll
                            scrollTrigger: {
                                trigger: el,
                                start: "top 85%",
                                toggleActions: "play none none none"
                            }
                        }
                    );
                });
            };

            document.addEventListener('astro:page-load', animateReveals);
            window.addEventListener('load', animateReveals);
        </script>
    </body>
</html>

<style is:global>
    /* Reset ultra-estricto */
    :root {
        overflow-x: hidden;
    }

    html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        max-width: 100vw;
        overflow-x: hidden;
        /* Evita el rebote elástico en iOS que a veces muestra el fondo blanco */
        overscroll-behavior-x: none;
    }

    /* Aseguramos que las imágenes no rompan el layout */
    img {
        max-width: 100%;
        height: auto;
    }

    .reveal {
        opacity: 0;
        /* Previene que el elemento ocupe espacio extra antes de la animación */
        will-change: transform, opacity;
    }
</style>