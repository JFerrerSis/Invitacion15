---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Map from "../components/Map.astro"; 
import Countdown from "../components/Countdown.astro";
import Dedication from '../components/Dedication.astro';
import { MessageCircle } from "@lucide/astro";

const datosEvento = {
  nombre: "Sofía Parra",
  direccion: "Hotel Jolie, AV Delicias con Calle 73",
  whatsapp: "584129183138", 
};

const nombreCorto = datosEvento.nombre.split(" ")[0];
const mensajeConfirmacion = encodeURIComponent(`¡Hola! Confirmo mi asistencia a los 15 de ${nombreCorto}.`);
---

<Layout title={`Invitación de 15 - ${datosEvento.nombre}`}>
  <main class="relative min-h-screen overflow-hidden">
    
    <section class="reveal w-full">
      <Hero />
    </section>

    <div class="relative z-10 w-full max-w-4xl mx-auto px-4 space-y-16 md:space-y-24">
      
      <section class="reveal with-sparkle-burst">
        <Dedication />
      </section>

      <section class="reveal with-sparkle-burst mt-8">
        <Countdown />
      </section>

      <div class="max-w-xl mx-auto border-t border-rose-200/30"></div>

      <section class="reveal with-sparkle-burst">
        <Map address={datosEvento.direccion} />
      </section>

      <section class="reveal with-sparkle-burst py-20 text-center space-y-8">
        <h2 class="font-anydore text-5xl md:text-7xl text-zinc-800 drop-shadow-sm">
          ¿Contamos contigo?
        </h2>

        <a 
          href={`https://wa.me/${datosEvento.whatsapp}?text=${mensajeConfirmacion}`}
          target="_blank"
          class="inline-flex items-center gap-3 bg-[#25D366] text-white px-10 py-5 rounded-full shadow-xl hover:shadow-[#25D366]/20 transition-all duration-500 font-bold transform hover:scale-105 active:scale-95 tracking-widest text-xs uppercase"
        >
          <MessageCircle class="size-6" />
          Confirmar por WhatsApp
        </a>
      </section>

    </div>

    <footer class="reveal py-24 relative overflow-hidden">
      <div class="flex items-center justify-center gap-4 mb-10 opacity-30">
        <div class="h-px w-12 bg-linear-to-r from-transparent to-rose-400"></div>
        <div class="w-1 h-1 rounded-full bg-rose-400"></div>
        <div class="h-px w-12 bg-linear-to-l from-transparent to-rose-400"></div>
      </div>

      <div class="container mx-auto px-6 text-center space-y-6">
        <div class="space-y-1">
          <p class="font-anydore text-2xl md:text-3xl text-zinc-800 drop-shadow-sm">
            Hecho con amor para {nombreCorto}
          </p>
        </div>
        <p class="text-[15px] text-zinc-400 italic opacity-60">
          © 2026 • Todos los derechos reservados
        </p>
      </div>

      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-64 h-32 bg-linear-to-t from-rose-100/30 to-transparent blur-3xl -z-10"></div>
    </footer>

  </main>
</Layout>

<style>
  @reference "tailwindcss";

  main {
    /* Gradiente suave que fluye con el scroll */
    background: linear-gradient(180deg, #f3e8ff 0%, #fce7f3 33%, #fffbeb 66%, #f3e8ff 100%);
    background-attachment: fixed;
    background-size: 100% 100%;
  }

  .font-anydore {
    font-family: 'Anydore', 'Parisienne', cursive;
  }

  /* Las clases .reveal ahora están controladas por el Layout, 
     pero mantenemos la opacidad inicial para evitar el flash de contenido (FOUC)
  */
  .reveal {
    opacity: 0;
  }
</style>