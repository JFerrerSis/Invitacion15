---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Map from "../components/Map.astro";
import MusicPlayer from "../components/MusicPlayer.astro";
import Countdown from "../components/Countdown.astro";
import Dedication from '../components/Dedication.astro';
import { MessageCircle } from "@lucide/astro";

const datosEvento = {
  nombre: "Sofía Valentina",
  direccion: "Salón de Eventos 'La Mansión', Calle Real #123",
  mapaLink: "https://maps.app.goo.gl/9SkZnjy76xCRgPqx6?g_st=iw",
  whatsapp: "5491122334455", 
};

const mensajeConfirmacion = encodeURIComponent(`¡Hola! Confirmo mi asistencia a los 15 de ${datosEvento.nombre.split(" ")[0]}.`);
---

<Layout title={`Invitación de 15 - ${datosEvento.nombre}`}>
  <main class="min-h-screen bg-global-gradient">
    
    <Hero />

    <div class="max-w-2xl mx-auto px-4">
      <Dedication />
    </div>

    <div class="max-w-xl mx-auto px-4 mt-[-2rem]">
      <Countdown />
    </div>

    <div class="max-w-xl mx-auto border-t border-zinc-950/5 my-10"></div>

    <Map address={datosEvento.direccion} mapUrl={datosEvento.mapaLink} />

    <MusicPlayer />

    <section class="py-20 px-6 text-center space-y-8 animate-fade-in">
      <h2 class="font-display text-4xl italic text-zinc-950">¿Contamos contigo?</h2>
      <p class="text-zinc-950/60 max-w-xs mx-auto font-light">
        Por favor, confirma tu asistencia antes del 1 de Octubre para esperarte con alegría.
      </p>
      
      <a 
        href={`https://wa.me/${datosEvento.whatsapp}?text=${mensajeConfirmacion}`}
        target="_blank"
        class="inline-flex items-center gap-3 bg-[#25D366] text-white px-10 py-4 rounded-full hover:shadow-xl hover:shadow-green-200 transition-all duration-300 font-medium transform hover:-translate-y-1"
      >
        <MessageCircle size={22} />
        Confirmar por WhatsApp
      </a>
    </section>

    <footer class="py-20 text-center opacity-40 italic font-light text-sm text-zinc-950">
      <p>Hecho con amor para {datosEvento.nombre.split(" ")[0]}</p>
      <p class="mt-2 uppercase tracking-widest text-[10px]">2026</p>
    </footer>

  </main>
</Layout>

<style>
  /* Degradado lila y rosado pastel para todo el fondo */
  .bg-global-gradient {
    background: linear-gradient(180deg, #f3e8ff 0%, #fce7f3 50%, #f3e8ff 100%);
    background-attachment: fixed; /* Mantiene el fondo fijo mientras haces scroll */
  }

  /* Animación suave al hacer scroll */
  .animate-fade-in {
    view-timeline-name: --section;
    view-timeline-axis: block;
    animation-timeline: --section;
    animation-name: show;
    animation-range: entry 25% cover 50%;
    animation-fill-mode: both;
  }

  @keyframes show {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>